# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App URL (used in OAuth callbacks + Stripe redirects) ──────
NEXT_PUBLIC_APP_URL=https://metal-vault-six.vercel.app

# ── Discogs API ───────────────────────────────────────────────
# Option A: OAuth app (full sync) — get from discogs.com/settings/developers
DISCOGS_KEY=your_consumer_key
DISCOGS_SECRET=your_consumer_secret

# Option B: Personal token (limited, no user OAuth)
DISCOGS_TOKEN=your_personal_token

# ── Spotify (optional — for "similar artists" feature) ───────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Stripe ───────────────────────────────────────────────────
# Get from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Create these prices in Stripe Dashboard → Products → Add product
# "Metal Vault Pro Monthly" → 9.99 PLN/month, recurring
# "Metal Vault Pro Yearly"  → 79.99 PLN/year, recurring
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# Webhook secret — get from Stripe Dashboard → Webhooks → Add endpoint
# Endpoint URL: https://your-app.vercel.app/api/stripe/webhook
# Events to listen: customer.subscription.*, checkout.session.completed, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Push Notifications (optional) ────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Email (optional — for weekly release digests) ─────────────
RESEND_API_KEY=
FROM_EMAIL=Metal Vault <noreply@yourdomain.com>

# ── Cron security ─────────────────────────────────────────────
# Any random string — add as Authorization: Bearer header in vercel.json crons
CRON_SECRET=your_random_secret_here
