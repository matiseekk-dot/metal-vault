# Spotify API — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Discogs API — https://www.discogs.com/settings/developers (Create App)
DISCOGS_KEY=your_discogs_consumer_key_here
DISCOGS_SECRET=your_discogs_consumer_secret_here

# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend — https://resend.com (free 3k emails/month)
RESEND_API_KEY=re_...
FROM_EMAIL=alerts@yourdomain.com

# App URL (for OAuth callbacks)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Cron secret (random string, set same in Vercel)
CRON_SECRET=your-random-secret-here

# VAPID Keys for Push Notifications
# Generate with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k);"
# Or use: https://vapidkeys.com
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
